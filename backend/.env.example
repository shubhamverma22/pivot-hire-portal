# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pivothire

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay (optional — leave blank for demo mode which auto-upgrades)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_PREMIUM=

# Brevo SMTP (for password reset emails — leave BREVO_SMTP_KEY blank to print links to console)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=                    # Your Brevo account/login email
BREVO_SMTP_KEY=                     # SMTP key from Brevo dashboard → SMTP & API → SMTP
FROM_EMAIL=noreply@pivothire.com
FROM_NAME=PivotHire

# Pricing (change these to update pricing everywhere — backend + frontend)
PREMIUM_PLAN_AMOUNT=1999
PREMIUM_PLAN_AMOUNT_PAISE=199900
PREMIUM_PLAN_CURRENCY=INR
PREMIUM_PLAN_NAME=PivotHire Premium
PREMIUM_PLAN_DESCRIPTION=Unlimited job applications — ₹1,999/month

# Misc
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
FRONTEND_URL=http://localhost:5173
